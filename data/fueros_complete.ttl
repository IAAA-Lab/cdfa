@prefix cdfa: <https://iaaa.es/cdfa/> .
@prefix dcam1: <http://purl.org/dcam/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dctype: <http://purl.org/dc/dcmitype/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

cdfa:Book a rdfs:Class ;
    rdfs:label "Book"@en ;
    rdfs:comment "A book containing civil law."@en ;
    rdfs:isDefinedBy cdfa: ;
    rdfs:subClassOf dctype:Text .

cdfa:Chapter a rdfs:Class ;
    rdfs:label "Chapter"@en ;
    rdfs:comment "A chapter inside a book part."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:Charter a rdfs:Class ;
    rdfs:label "Charter"@en ;
    dcam1:memberOf cdfa:PartType ;
    rdfs:comment "A written grant by the sovereign or legislative power of a country, by which a body such as a city, company, or university is founded or its rights and privileges defined."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:CharterNotInUse a rdfs:Class ;
    rdfs:label "Charters not inuse"@en ;
    dcam1:memberOf cdfa:PartType ;
    rdfs:comment "Charters not in use."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:CourtAct a rdfs:Class ;
    rdfs:label "Court Act"@en ;
    dcam1:memberOf cdfa:PartType ;
    rdfs:comment "Court Act."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:CourtEvent a rdfs:Class ;
    rdfs:label "CourtEvent"@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:NewCharter a rdfs:Class ;
    rdfs:label "NewCharter"@en ;
    dcam1:memberOf cdfa:PartType ;
    rdfs:comment "New charters."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:Observance a rdfs:Class ;
    rdfs:label "Observance"@en ;
    dcam1:memberOf cdfa:PartType ;
    rdfs:comment "Observances."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:Part a rdfs:Class ;
    rdfs:label "Part"@en ;
    rdfs:comment "A part inside a book."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:Phrase a rdfs:Class ;
    rdfs:label "Phrase"@en ;
    rdfs:comment "A phrase contained in a section of description of a court event."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:Section a rdfs:Class ;
    rdfs:label "Section"@en ;
    rdfs:comment "A section inside a chapter."@en ;
    rdfs:isDefinedBy cdfa: .

cdfa:book-1 a cdfa:Book ;
    dct:hasPart cdfa:part-fueros ;
    dct:title "Fueros, Observancias y Actos de Corte del Reino de Aragón"@es,
        "Fororum, Observantiae et Actorum Curiarum Regni Aragonum"@la .

cdfa:chairedBy a rdf:Property ;
    rdfs:label "chaired by"@en ;
    rdfs:comment "This property links a court event with the person chairing the event."@en ;
    rdfs:domain cdfa:CourtEvent ;
    rdfs:isDefinedBy cdfa: ;
    rdfs:range foaf:Person .

cdfa:chronologicalVersionPage a rdf:Property ;
    rdfs:label "chaired by"@en ;
    rdfs:comment "The page containing the original text in the chronological version of the book."@en ;
    rdfs:domain cdfa:CourtEvent,
        cdfa:Section ;
    rdfs:isDefinedBy cdfa: ;
    rdfs:range rdfs:Literal .

cdfa:courtevent-560 a cdfa:CourtEvent ;
    dct:date "1235" ;
    dct:hasPart cdfa:phrase-court-560-2713 ;
    dct:spatial cdfa:location-zaragoza ;
    dct:title "Jaime Primero. Zaragoza, 1235."@es ;
    cdfa:chairedBy cdfa:person-jaime_primero .

cdfa:systematicVersionPage a rdf:Property ;
    rdfs:label "chaired by"@en ;
    rdfs:comment "The page containing the original text in the systematic version of the book."@en ;
    rdfs:domain cdfa:Section ;
    rdfs:isDefinedBy cdfa: ;
    rdfs:range rdfs:Literal .

