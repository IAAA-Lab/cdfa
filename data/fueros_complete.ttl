    dct:relation cdfa:courtevent-520 ;
    dct:title "Juramento que tiene que prestar el Procurador sobre cualquier excepción."@es,
        "De iuramento prestando per Procuratorem super exceptionibus quibuscumque."@la ;
    cdfa:chronologicalVersionPage "f.64." ;
    cdfa:systematicVersionPage "80a" .

cdfa:section-2-93 a cdfa:Section ;
    dct:hasPart cdfa:phrase-2-93-848,
        cdfa:phrase-2-93-849 ;
    dct:relation cdfa:courtevent-520 ;
    dct:title "El Procurador pnede ser admitido a jurar sobre las ignorancias."@es,
        "Ut procurator super inscientiis admitti valeat ad iurandum."@la ;
    cdfa:chronologicalVersionPage "f.64." ;
    cdfa:systematicVersionPage "80a" .

cdfa:section-2-94 a cdfa:Section ;
    dct:hasPart cdfa:phrase-2-94-879,
        cdfa:phrase-2-94-880 ;
    dct:relation cdfa:courtevent-517 ;
    dct:title "Forma de la procuracion que deben llevar los Procuradores enviados por las Ciudades y otros lugares a las Cortes generales de Aragón."@es,
        "De forma Procuratorii quod debent portare Procuratores qui à Civitatibus, & aliis locis mittuntur ad Curias generales Aragonum."@la ;
    cdfa:chronologicalVersionPage "f.48." ;
    cdfa:systematicVersionPage "80b" .

cdfa:section-2-95 a cdfa:Section ;
    dct:hasPart cdfa:phrase-2-95-892 ;
    dct:relation cdfa:courtevent-520 ;
    dct:title "Los hermanos o allegados del que se ausenta del Reino de Aragón durante diez anlos pueden recuperar los bienes de éste de manos del Procurador que él mismo constituyo antes."@es,
        "Ut fratres, vel propinqui absentis à Regno Aragonum per decem annos recuperare valeant bona ipsius absentis à Procuratore per ipsum ante constituto."@la ;
    cdfa:chronologicalVersionPage "f.63." ;
    cdfa:systematicVersionPage "81a" .

cdfa:section-2-96 a cdfa:Section ;
    dct:hasPart cdfa:phrase-2-96-547,
        cdfa:phrase-2-96-548,
        cdfa:phrase-2-96-549 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "Por comparecencia o por proceso del principal en la causa sin protesta, no se considerarán revocados sus Procuradores."@es,
        "Ut per comparitionem, vel per processum principalis in causa, absque protestatione Procuratores sul non censeantur revocati."@la ;
    cdfa:chronologicalVersionPage "f.61." ;
    cdfa:systematicVersionPage "81a" .

