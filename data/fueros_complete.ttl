        cdfa:phrase-7-350-83,
        cdfa:phrase-7-350-84 ;
    dct:relation cdfa:courtevent-516 ;
    dct:title "Cuántas caballerias pueden retener los Barones en su beneficio."@es,
        "De Baronibus quot Cavallerias ad opus sui valeant retinere."@la ;
    cdfa:chronologicalVersionPage "f.45." ;
    cdfa:systematicVersionPage "250b" .

cdfa:section-7-351 a cdfa:Section ;
    dct:hasPart cdfa:phrase-7-351-86,
        cdfa:phrase-7-351-87 ;
    dct:relation cdfa:courtevent-518 ;
    dct:title "Los Barones de Aragón no entreguen ni asignen la tierra y los dineros que tengan en honor sino a quienes sean del Reino."@es,
        "De Daronibus Aragonum ut terram, & denarios quam pro honore tenuerint, non dent, nec assignent, nisi illis qui sunt de Regno."@la ;
    cdfa:chronologicalVersionPage "f.45." ;
    cdfa:systematicVersionPage "250b" .

