    dct:hasPart cdfa:phrase-7-346-1255 ;
    dct:relation cdfa:courtevent-513 ;
    dct:title "Tributos y tributarios."@es,
        "De stipendiis, & stipendiaris."@la ;
    cdfa:chronologicalVersionPage "f.25." ;
    cdfa:systematicVersionPage "249b" .

cdfa:section-7-347 a cdfa:Section ;
    dct:hasPart cdfa:phrase-7-347-279,
        cdfa:phrase-7-347-280 ;
    dct:relation cdfa:courtevent-515 ;
    dct:title "Los Barones de Aragón tengan enmienda sobre sus Caballerias de los Lugares de los que el señor Rey haya hecho gracia."@es,
        "Ut Barones Aragonum habeant emendam de suis Cavalleriis illorum Locorum de quibus dominus Rex fecerit gratiam."@la ;
    cdfa:chronologicalVersionPage "f.43." ;
    cdfa:systematicVersionPage "250a" .

cdfa:section-7-348 a cdfa:Section ;
    dct:hasPart cdfa:phrase-7-348-282,
        cdfa:phrase-7-348-283 ;
    dct:relation cdfa:courtevent-515 ;
    dct:title "Los Barones de Aragón tengan que dar honores a sus Caballeros."@es,
        "Quod Barones Aragonum teneantur honores Militibus suis dare."@la ;
    cdfa:chronologicalVersionPage "f.43." ;
    cdfa:systematicVersionPage "250a" .

cdfa:section-7-349 a cdfa:Section ;
    dct:hasPart cdfa:phrase-7-349-285 ;
    dct:relation cdfa:courtevent-515 ;
    dct:title "Barones y Caballeros estén obligados a servir por los dineros que recibieron del señor Rey, o los Caballeros de los Barones, que no sean de honor."@es,
        "Quod Barones, & Milites teneantur servire pro denaris: quos à domino Rege receperint, vel Milites à Baronibus qui non sint pro honore."@la ;
    cdfa:chronologicalVersionPage "f.43." ;
    cdfa:systematicVersionPage "250a" .

cdfa:section-7-350 a cdfa:Section ;
    dct:hasPart cdfa:phrase-7-350-80,
