cdfa:section-1-45 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-45-513,
        cdfa:phrase-1-45-514,
        cdfa:phrase-1-45-515 ;
    dct:relation cdfa:courtevent-521 ;
    dct:title "El Justicia de Aragón tiene que aconsejar a los Sobrejunteros en las cosas que le lleven a consulta, pero a los demás Jueces sólo en los casos criminales y en las causas civiles dificiles."@es,
        "Quod Hustitia Araponum teneatur consulere Supraiunctariis, in iis quibus eundem duxerint consulendum. Alios vero Iudices in casibus criminalibus, & causis civilibus arduis tantum."@la ;
    cdfa:chronologicalVersionPage "f.68." ;
    cdfa:systematicVersionPage "46b" .

cdfa:section-1-46 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-46-517,
        cdfa:phrase-1-46-518,
        cdfa:phrase-1-46-519 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "En el futuro habrá oficio de la Bailía general en el Reino de Aragón, según se acostumbró antes."@es,
        "Quod de cætero officium Baiullæ generalis sit in Regno Aragonum, ut anteà consuevit."@la ;
    cdfa:chronologicalVersionPage "f.62." ;
    cdfa:systematicVersionPage "48b" .

