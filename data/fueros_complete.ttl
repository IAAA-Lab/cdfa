    dct:relation cdfa:courtevent-525 ;
    dct:title "Comisarios, Porteros y Notarios de la judicatura serán Aragoneses y no de otra nación, y estarán domiciliados en este Reino."@es,
        "Quod Commissarii, Portaril, & Notarii iudicatura sint Aragonenses, & non alterius nationis, & domiciliati in eodem Regno."@la ;
    cdfa:chronologicalVersionPage "f.72." ;
    cdfa:systematicVersionPage "67b" .

