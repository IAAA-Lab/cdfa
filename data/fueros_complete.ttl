        "De Decimis Christianorum."@la ;
    cdfa:chronologicalVersionPage "f.31." ;
    cdfa:systematicVersionPage "10b" .

cdfa:section-1-9 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-9-151,
        cdfa:phrase-1-9-152,
        cdfa:phrase-1-9-153,
        cdfa:phrase-1-9-154,
        cdfa:phrase-1-9-155 ;
    dct:relation cdfa:courtevent-516 ;
    dct:title "El señor Rey, en la Corte, puede hacer Estatutos y Fueros con el asentimiento y la voluntad de quienes han acudido a la Corte. Y todos los ausentes están obligados a guardar esos Estatutos y Fueros."@es,
        "Quod dominus Rex possit facere in Curia Statuta, & Foros de voluntate, & assensu illorum, qui ad Curiam venerint: & omnes absentes teneantur illa Statula, & Foros observare."@la ;
    cdfa:chronologicalVersionPage "f.46." ;
    cdfa:systematicVersionPage "10b" .

