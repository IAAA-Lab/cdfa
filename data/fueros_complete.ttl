        cdfa:phrase-1-25-260,
        cdfa:phrase-1-25-261 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "El Regente el oficio de la Gobernación será un simple Caballero."@es,
        "Quod Regens oficium Gubernationis sit Miles simplex."@la ;
    cdfa:chronologicalVersionPage "f.56." ;
    cdfa:systematicVersionPage "33a" .

cdfa:section-1-26 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-26-215 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "Los Regentes el oficio de la Gobernación no podrán nombrar a otro Regente del mismo oficio."@es,
        "De Regentibus officium Gubernationis, ut non possint alium Regeniem ipsum officium facere."@la ;
    cdfa:chronologicalVersionPage "f.59." ;
    cdfa:systematicVersionPage "36a" .

