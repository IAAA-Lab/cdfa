cdfa:section-1-15 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-15-208,
        cdfa:phrase-1-15-209,
        cdfa:phrase-1-15-210 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "El Privilegio general y su declaración seránFueros y se tendrán y guardarán como Fueros."@es,
        "Quod Prrivilegium generale, & declaratio ipsius sint Fori, & pro Foris habeantur, & observentur."@la ;
    cdfa:chronologicalVersionPage "f.59." ;
    cdfa:systematicVersionPage "21a" .

cdfa:section-1-16 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-16-229 ;
    dct:relation cdfa:courtevent-523 ;
    dct:title "Los Fueros y Ordinaciones que se hicieron en la villa de Monzón se tendrán y serán considerados por Fueros de Aragón."@es,
        "Quod Fori, & ordinationes qui facti fuerunt in villa Montisoni pro Foris Aragonum habeantur, & teneantur."@la ;
    cdfa:chronologicalVersionPage "f.71." ;
    cdfa:systematicVersionPage "22b" .

cdfa:section-1-17 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-17-231,
        cdfa:phrase-1-17-232,
        cdfa:phrase-1-17-233 ;
    dct:relation cdfa:courtevent-515 ;
    dct:title "Ribagorza y Litera son del Reino de Aragón hasta la clamor de Almacellas."@es,
        "Quod Ripacurcia, & Litera usque ad clamorem de Almacillis sint de Regno Aragonum."@la ;
    cdfa:chronologicalVersionPage "f.44." ;
    cdfa:systematicVersionPage "23a" .

cdfa:section-1-18 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-18-243,
        cdfa:phrase-1-18-244,
        cdfa:phrase-1-18-245,
        cdfa:phrase-1-18-246,
        cdfa:phrase-1-18-247,
        cdfa:phrase-1-18-248 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "Lo que tienen obligación de hacer y procurar el Señor Rey y sus sucesores, el Gobernador de Aragón y quienes le hagan las veces, el Justicia de Aragón y los demás Jueces y Oficiales para que se respeten los Fueros de Aragón."@es,
        "De iis que Dominus Rex, & alii successores ipsius, gubernator Aragonum, & eius vicem gerentes, Iustitia Aragonum, & alii Iudices, & Officiales facere, & servare tenentur, ut Fori Aragonum conserventur."@la ;
    cdfa:chronologicalVersionPage "f.56." ;
    cdfa:systematicVersionPage "25a" .

cdfa:section-1-19 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-19-263,
        cdfa:phrase-1-19-264 ;
    dct:relation cdfa:courtevent-515 ;
    dct:title "El señor Rey oirá en Audiencia a los demandantes el Viernes o el Sábado."@es,
        "Ut dominus Rex in Audientia die Veneris, vel Sabbati audiat conquerentes."@la ;
    cdfa:chronologicalVersionPage "f.43." ;
    cdfa:systematicVersionPage "26b" .

cdfa:section-1-2 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-2-14 ;
    dct:relation cdfa:courtevent-513 ;
    dct:title "Quienes buscan refugio en Iglesias o en Palacios de Infanzones."@es,
        "De his qui ad Ecelesias confugiunt, vel Palatia Infantionum."@la ;
    cdfa:chronologicalVersionPage "f.7." ;
    cdfa:systematicVersionPage "1b" .

cdfa:section-1-20 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-20-212,
        cdfa:phrase-1-20-213 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "El señor Rey tiene que llevar consigo dos caballeros y dos jurisperitos, con los que despachara los asuntos de Aragón."@es,
        "Quod dominus Rex teneatur duos milites, & duos iurisperitos secum ducere, cum quibus negolia Aragonum expediantur."@la ;
    cdfa:chronologicalVersionPage "f.59." ;
    cdfa:systematicVersionPage "26b" .

cdfa:section-1-21 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-21-300,
        cdfa:phrase-1-21-301,
        cdfa:phrase-1-21-302,
        cdfa:phrase-1-21-303 ;
    dct:relation cdfa:courtevent-524 ;
    dct:title "El señor Rey no puede nombrar un Lugarteniente suyo en Aragón sino en ciertos casos."@es,
        "Quod dominus Rex non possit facere Locumtenentem ipsius in Aragonia, nisi in certis casibus."@la ;
    cdfa:chronologicalVersionPage "f.72." ;
    cdfa:systematicVersionPage "27a" .

cdfa:section-1-22 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-22-311,
        cdfa:phrase-1-22-312,
        cdfa:phrase-1-22-313 ;
    dct:relation cdfa:courtevent-559 ;
    dct:title "Prórroga de las deudas."@es,
        "De clongatione debitorum."@la ;
    cdfa:chronologicalVersionPage "f.35." ;
    cdfa:systematicVersionPage "27a" .

cdfa:section-1-23 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-23-176,
        cdfa:phrase-1-23-177,
        cdfa:phrase-1-23-178,
        cdfa:phrase-1-23-179 ;
    dct:relation cdfa:courtevent-526 ;
    dct:title "El señor Rey no pondrá ni nombrará Lugartenientes de los Sobrejunteros, y los Sobrejunteros responderán y quedarán obligados por sus Lugartenientes."@es,
        "Ne dominus Rex Locumtenentes Supraiunctariorum ponat, seu constituat, & quod Supraiunctarii pro suis Locumtenentibus teneantur, & obligati existant."@la ;
    cdfa:chronologicalVersionPage "f.75." ;
    cdfa:systematicVersionPage "27b" .

cdfa:section-1-24 a cdfa:Section ;
    dct:hasPart cdfa:phrase-1-24-335,
        cdfa:phrase-1-24-336,
        cdfa:phrase-1-24-337,
        cdfa:phrase-1-24-338,
        cdfa:phrase-1-24-339 ;
    dct:relation cdfa:courtevent-523 ;
    dct:title "El Primogénito podrá ejercer el oficio de la Gobernación y su Jurisdicción."@es,
        "Qnod Primogenitus possit officium Gubernationis, & ipsius Iurisdictionem exercere."@la ;
    cdfa:chronologicalVersionPage "f.70." ;
    cdfa:systematicVersionPage "28a" .

