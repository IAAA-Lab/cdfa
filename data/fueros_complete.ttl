        cdfa:phrase-1-70-545 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "Los Jueces de Aragón y no otros juzgarán y oiran las causas, y harán las declaraciones."@es,
        "Ut Iudices Qragonun iudicent, & audiant causas, & relationes faciant, & non alii."@la ;
    cdfa:chronologicalVersionPage "f.61." ;
    cdfa:systematicVersionPage "70b" .

