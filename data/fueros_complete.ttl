        cdfa:phrase-1-47-542 ;
    dct:relation cdfa:courtevent-519 ;
    dct:title "Los Administradores de Aragón de los oficios del senor Rey tienen que dar cuenta, y en qué lugar deben mantenerse los registros del Reino de Aragón."@es,
        "Ut Administratores Aragonum officiorum domini Regis rafionem reddere teneantur: & in quo loco registra Regni Aragonum debeant remanere."@la ;
    cdfa:chronologicalVersionPage "f.61." ;
    cdfa:systematicVersionPage "49a" .

